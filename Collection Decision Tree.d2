sets: Sets {
  is_set_iteration_needed: Iteration or \n determinism needed? {
    class: decision
  }
  is_set_iteration_needed -> linked_set: Yes {
    class: arrow
  }
  is_set_iteration_needed -> set: No {
    class: arrow
  }

  linked_set: Linked set {
    class: collection_type
  }
  linked_set -> linked_hash_set: Java {
    class: arrow
  }
  linked_set -> boost_multi_index: C++ {
    class: arrow
  }

  set: Set {
    class: collection_type
  }
  set -> std_unordered_set: C++ {
    class: arrow
  }
  set -> python_set: Python {
    class: arrow
  }
  set -> hashset: Java {
    class: arrow
  }

  linked_hash_set: LinkedHashSet {
    class: collection
    link: https://docs.oracle.com/javase/26/docs/api/java/util/LinkedHashSet.html
  }

  std_unordered_set: std::unordered_set {
    class: collection
    link: https://en.cppreference.com/w/cpp/container/unordered_set
  }
  python_set: set {
    class: collection
    link: "https://docs.python.org/3/library/stdtypes.html#set"
  }
  hashset: HashSet {
    class: collection
