arrays: Arrays {
  array: Array {
    class: collection_type
  }
  array -> numpy_array: Python {
    class: arrow
  }
  array -> std_array: C++ {
    class: arrow
  }
  array -> java_array: Java {
    class: arrow
  }

  is_member_default_constructible: Default-constructible members? {
    class: decision
  }
  is_member_default_constructible -> array: Yes {
    class: arrow
  }
  is_member_default_constructible -> dynamic_arrays.dynamic_array_continuous_memory: No {
    class: arrow
  }

  numpy_array: numpy.array {
    class: collection
    link: https://numpy.org/doc/stable/reference/generated/numpy.array.html
  }

  std_array: std::array {
    class: collection
    link: https://en.cppreference.com/w/cpp/container/array
  }

  java_array: "[]" {
    class: collection
    link: https://docs.oracle.com/en/java/javase/14/docs/api/java.base/java/util/ArrayList.html
  }

  java_dynamic_array_continuous_memory_dependency_acceptable {
    class: [decision; decision_dependency]
  }
  java_dynamic_array_continuous_memory_dependency_acceptable -> dynamic_arrays.dynamic_array_continuous_memory: Yes {
    class: arrow
  }
  java_dynamic_array_continuous_memory_dependency_acceptable -> memory_critical_and_primitive_members: No {
    class: arrow
  }

  memory_critical_and_primitive_members: Memory critical \n AND \n primitive members \n (int, float)? {
    class: decision
  }
  memory_critical_and_primitive_members -> array: Yes {
    class: arrow
  }
  memory_critical_and_primitive_members -> dynamic_arrays.dynamic_array_non_continuous_memory: No {
    class: arrow
  }

  dynamic_arrays: Dynamic arrays {
    dynamic_array_continuous_memory: Dynamic array with \n continuous memory {
      class: collection_type
    }
    dynamic_array_continuous_memory -> std_vector: C++ {
      class: arrow
    }
    dynamic_array_continuous_memory -> python_array: Python {
      class: arrow
    }
    dynamic_array_continuous_memory -> fastutil: Java {
      class: arrow
    }

    dynamic_array_non_continuous_memory: Dynamic array with \n non-continuous memory {
      class: collection_type
    }
    dynamic_array_non_continuous_memory -> python_list: Python {
      class: arrow
    }
    dynamic_array_non_continuous_memory -> array_list: Java {
      class: arrow
    }

    std_vector: std::vector {
      class: collection
      link: https://en.cppreference.com/w/cpp/container/vector
    }

    python_array: array {
      class: collection
      link: https://docs.python.org/3/library/array.html
    }

    fastutil: fastutil {
      class: collection
      link: https://github.com/vigna/fastutil
    }

    python_list: "[]" {
      class: collection
      link: "https://docs.python.org/3/library/stdtypes.html#sequence-types-list-tuple-range"
    }

    array_list: ArrayList {
      class: collection
      link: https://docs.oracle.com/en/java/javase/26/docs/api/java.base/java/util/ArrayList.html
    }
  }
}

