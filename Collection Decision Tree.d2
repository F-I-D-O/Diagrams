# Collection Decision Tree
# Converted from draw.io — edit layout in D2 as needed.

direction: down

classes: {
  decision: {
    shape: diamond
    width: 250
    height: 250
  }

  decision_dependency: {
    label: "Dependency Acceptable?"
  }

  arrow: {
    style: {
      font-size: 20
      italic: false
      bold: true
    }
  }

  collection_type: {
    shape: rectangle
    width: 180
    height: 60
  }

  collection: {
    shape: rectangle
    width: 180
    height: 60
    style: {
      border-radius: 100
    }
  }
}

start: "Start Here" {
  notice: |md
    - Author: David Fiedler
    - License: [CC BY 4.0](https://creativecommons.org/licenses/by/4.0/)
    - Repository and Issues: [GitHub](https://github.com/F-I-D-O/Diagrams)
  |
  style: {
    border-radius: 100
  }
}
start -> index_or_not



dict: dict
dict.shape: rectangle

index_or_not: Do you need \n index->value mapping? \n (searching in collection, ...) {
  class: decision
}
index_or_not -> index_type: Yes {
  class: arrow
}
index_or_not -> contains_needed: No {
  class: arrow
}

index_type: Index Type: {
  class: decision
}
index_type -> is_size_constant: Natural numbers, \n all/most indexes are used. {
  class: arrow
}
index_type -> kdtree: Distance to point {
  class: arrow
}
index_type -> rtree: Distance to \n line or shape {
  class: arrow
}
index_type -> maps.ordered_keys_needed: General {
  class: arrow
}

contains_needed: Frequent need of checking \n if the collection contains \n some member? {
  class: decision
}
contains_needed -> sets.is_set_iteration_needed: Yes {
  class: arrow
}
contains_needed -> fast_removal_needed: No {
  class: arrow
}

kdtree: KDTree {
  class: collection_type
}

rtree: RTree {
  class: collection_type
}

fast_removal_needed: Do you need to remove \n from the collection often? {
  class: decision
}
fast_removal_needed -> removal_type: Yes {
  class: arrow
}
fast_removal_needed -> is_size_constant: No {
  class: arrow
}

is_size_constant: Fixed size? {
  class: decision
}
is_size_constant -> heterogenous_values: Yes {
  class: arrow
}
is_size_constant -> arrays.dynamic_arrays.dynamic_array_continuous_memory: No (C++, Python) {
  class: arrow
}
is_size_constant -> arrays.java_dynamic_array_continuous_memory_dependency_acceptable: No (Java) {
  class: arrow
}

heterogenous_values: Heterogenous value types? {
  class: decision
}
heterogenous_values -> tuple: Yes {
  class: arrow
}
heterogenous_values -> java_record: Yes, Java {
  class: arrow
}
heterogenous_values -> arrays.array: No {
  class: arrow
}
heterogenous_values -> arrays.is_member_default_constructible: No, C++ {
  class: arrow
}

removal_type: Removal Type: {
  class: decision
}
removal_type -> queue: FIFO {
  class: arrow
}
removal_type -> linked_list: Neighboring \n indicies {
  class: arrow
}
removal_type -> arrays.dynamic_arrays.dynamic_array_continuous_memory: Neighboring \n indicies, Python {
  class: arrow
}
removal_type -> arrays.dynamic_arrays.dynamic_array_continuous_memory: Random {
  class: arrow
}
removal_type -> arrays.java_dynamic_array_continuous_memory_dependency_acceptable: Random, Java {
  class: arrow
}

tuple: Tuple {
  class: collection_type
}
tuple -> python_tuple: Python {
  class: arrow
}
tuple -> is_pair: C++ {
  class: arrow
}

